#: install-libdvd-pkg-butterfly.sh
msgid "<b>libdvd-pkg installation</b>\n\nThis program will install the libdvdcss2 library to decrypt DRM-protected commercial DVD videos.\n\nAn active internet connection is required.\n\nDo you want to continue?"
msgstr "<b>Installation de libdvd-pkg</b>\n\nCe programme installera la bibliothèque libdvdcss2 pour déchiffrer les DVD vidéos dotés de DRM (Digital Rights Management).\n\nUne connexion internet fonctionnelle est nécessaire.\n\nVoulez-vous continuer ?"

#: install-libdvd-pkg-butterfly.sh
msgid "Install"
msgstr "Installer"

#: install-libdvd-pkg-butterfly.sh
msgid "Later"
msgstr "Plus tard"

#: install-libdvd-pkg-butterfly.sh
msgid "Installation in progress, please wait..."
msgstr "Installation en cours, veuillez patienter..."

#: install-libdvd-pkg-butterfly.sh
msgid "Configuring libdvdcss2, please wait..."
msgstr "Configuration de libdvdcss2 en cours..."

#: install-libdvd-pkg-butterfly.sh
msgid "<b>Installation complete</b>\n\nlibdvdcss2 has been successfully installed.\nYou can now play DVD videos on your PC."
msgstr "<b>Installation terminée</b>\n\nlibdvdcss2 a été installé avec succès.\nVous pouvez maintenant lire les DVD vidéo sur votre PC."

#: install-libdvd-pkg-butterfly.sh
msgid "Close"
msgstr "Fermer"

#: install-libdvd-pkg-butterfly.sh
msgid "<b>Installation failed</b>\n\nAn error occurred during installation.\nPlease try again."
msgstr "<b>Échec de l'installation</b>\n\nUne erreur est survenue pendant l'installation.\nVeuillez réessayer."
